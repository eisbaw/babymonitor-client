# APK / app binaries
*.apk
*.xapk
*.apks
*.aab

# Extraction & decompilation output (large, regenerable)
extracted/
decompiled/
decompiled_csharp/
analysis/
reports/

# Secrets, credentials, captures, PII
secrets/
*.har
*.pcap
*.pcapng
*.keystore
# Defensive: catch secret artifacts a subagent might write outside secrets/
tuya_appkey.json
*appsecret*
*.token
token_store*
# `fixtures/` is ignored defensively because a CAPTURED-response fixture would
# carry real account PII/secrets. EXCEPTION: the Rust crate's test fixtures are
# SYNTHETIC (obviously-fake SYNTH_*/synth-* values, no real capture exists — this
# is a static-analysis-only project), so they are deliberately committable and
# un-ignored below. `just secret-scan` still scans them. Never place a real
# capture under this path.
fixtures/
# Un-ignore ONLY the two known synthetic fixtures by name (not the whole tree),
# so a future stray file dropped under tests/fixtures/ is ignore-by-default and
# cannot be accidentally committed. (secret-scan remains the backstop.)
# We must (1) un-ignore the dir so git descends into it, (2) re-ignore everything
# inside it, then (3) re-include exactly the two known fixture files.
!babymonitor/babymonitor-core/tests/fixtures/
babymonitor/babymonitor-core/tests/fixtures/*
!babymonitor/babymonitor-core/tests/fixtures/device_list.json
!babymonitor/babymonitor-core/tests/fixtures/camera_info.json

# Rust
target/

# Python (the grounding gate scripts are run via python3 — bytecode is local).
__pycache__/
*.pyc

# Claude Code harness runtime state (session locks contain a sessionId/pid —
# local runtime artifacts, never project source; must not be tracked).
.claude/scheduled_tasks.lock
.claude/*.lock

# Editor / OS
.direnv/
result
result-*
*.swp
.DS_Store

# Backlog tool runtime artifact
backlog/email-preferences.json

# Live emulator network captures (contain real deviceId/appKey/signatures).
# Tracked intentionally for RE; LOCAL ONLY — do NOT push without redacting.
